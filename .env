# ============================================================
# DEEPFAKESHIELD - CONFIGURACIÓN DE AUDIO
# ============================================================

# Voz hablada generada mediante IA
AUDIO_AI_VOICE_MODEL_NAME=garystafford/wav2vec2-deepfake-voice-detector

# Música o canciones generadas mediante IA
AUDIO_AI_MUSIC_MODEL_NAME=AI-Music-Detection/ai_music_detection_large_60s

# Voz sintética, clonada o manipulada
AUDIO_DEEPFAKE_MODEL_NAME=MelodyMachine/Deepfake-audio-detection-V2

AUDIO_SAMPLE_RATE=16000
MAX_AUDIO_SECONDS=60
AUDIO_MIN_SECONDS=2.5

# Segmentación
AUDIO_CHUNK_SECONDS=5
AUDIO_CHUNK_OVERLAP_SECONDS=2.5
AUDIO_MAX_CHUNKS=8
AUDIO_TRIM_TOP_DB=35

# Umbrales iniciales
AUDIO_AI_THRESHOLD=82
AUDIO_AI_REAL_THRESHOLD=82

AUDIO_DEEPFAKE_THRESHOLD=82
AUDIO_DEEPFAKE_REAL_THRESHOLD=82

AUDIO_MIN_VOTE_RATIO=0.60

# Advertencia de saturación
AUDIO_MAX_CLIPPING_RATIO=0.05

HF_LOCAL_ONLY=false
USE_CUDA=false  